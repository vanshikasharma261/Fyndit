<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Invoice {{invoiceNumber}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 12px; color: #333; background: #fff; }
    .wrapper { max-width: 800px; margin: 0 auto; }

    .header { background: #1a2744; color: #fff; padding: 24px 32px; display: flex; justify-content: space-between; align-items: center; }
    .brand { font-size: 28px; font-weight: 700; letter-spacing: 3px; color: #ff5c35; }
    .invoice-label { font-size: 13px; font-weight: 600; letter-spacing: 1px; color: #cbd5e1; text-transform: uppercase; }

    .meta-row { padding: 18px 32px; border-bottom: 1px solid #e5e7eb; display: flex; gap: 48px; background: #f8fafc; }
    .meta-block { display: flex; flex-direction: column; gap: 3px; }
    .meta-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; }
    .meta-value { font-size: 12px; font-weight: 600; color: #1a2744; }

    .addresses { padding: 20px 32px; display: flex; gap: 48px; border-bottom: 1px solid #e5e7eb; }
    .addr-block { flex: 1; }
    .addr-title { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 8px; }
    .addr-name { font-size: 13px; font-weight: 600; color: #1a2744; margin-bottom: 3px; }
    .addr-line { font-size: 12px; color: #374151; line-height: 1.6; }

    .items-section { padding: 20px 32px; }
    .section-heading { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 12px; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #f1f2f4; }
    thead th { padding: 8px 10px; text-align: left; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; color: #6b7280; border-bottom: 2px solid #e5e7eb; }
    thead th.right { text-align: right; }
    tbody td { padding: 10px 10px; border-bottom: 1px solid #f1f2f4; font-size: 12px; vertical-align: top; color: #374151; }
    tbody td.right { text-align: right; font-weight: 500; color: #1a2744; }
    tbody tr:last-child td { border-bottom: none; }

    .totals-wrap { padding: 4px 32px 20px; display: flex; justify-content: flex-end; }
    .totals-box { width: 280px; border-top: 1px solid #e5e7eb; padding-top: 12px; }
    .totals-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 12px; color: #374151; }
    .totals-row.discount { color: #16a34a; }
    .totals-row.grand { border-top: 2px solid #1a2744; margin-top: 6px; padding-top: 10px; font-size: 14px; font-weight: 700; color: #1a2744; }
    .free-ship { color: #16a34a; font-weight: 600; }

    .footer { background: #1a2744; padding: 16px 32px; text-align: center; }
    .footer p { font-size: 11px; color: #94a3b8; line-height: 1.7; }
    .footer .brand-accent { color: #ff5c35; font-weight: 700; }
    .footer .small { font-size: 10px; color: #64748b; margin-top: 4px; }
  </style>
</head>
<body>
  <div class="wrapper">

    <div class="header">
      <div class="brand">FYNDIT</div>
      <div class="invoice-label">Tax Invoice</div>
    </div>

    <div class="meta-row">
      <div class="meta-block">
        <span class="meta-label">Invoice Number</span>
        <span class="meta-value">{{invoiceNumber}}</span>
      </div>
      <div class="meta-block">
        <span class="meta-label">Invoice Date</span>
        <span class="meta-value">{{date}}</span>
      </div>
      <div class="meta-block">
        <span class="meta-label">Order Number</span>
        <span class="meta-value">{{orderNumber}}</span>
      </div>
      <div class="meta-block">
        <span class="meta-label">Payment Method</span>
        <span class="meta-value">{{paymentMethod}}</span>
      </div>
    </div>

    <div class="addresses">
      <div class="addr-block">
        <div class="addr-title">Billed To</div>
        <div class="addr-name">{{user.name}}</div>
        <div class="addr-line">{{user.email}}</div>
      </div>
      <div class="addr-block">
        <div class="addr-title">Shipped To</div>
        <div class="addr-name">{{user.name}}</div>
        <div class="addr-line">{{shipTo.line1}}</div>
        {{#if shipTo.line2}}<div class="addr-line">{{shipTo.line2}}</div>{{/if}}
        <div class="addr-line">{{shipTo.city}}, {{shipTo.state}} — {{shipTo.zip}}</div>
        <div class="addr-line">{{shipTo.country}}</div>
      </div>
    </div>

    <div class="items-section">
      <div class="section-heading">Order Items</div>
      <table>
        <thead>
          <tr>
            <th style="width:30px;">#</th>
            <th>Product Description</th>
            <th class="right" style="width:50px;">Qty</th>
            <th class="right" style="width:100px;">Unit Price</th>
            <th class="right" style="width:100px;">Amount</th>
          </tr>
        </thead>
        <tbody>
          {{#each items}}
          <tr>
            <td>{{sno}}</td>
            <td>{{product_name}}</td>
            <td class="right">{{quantity}}</td>
            <td class="right">&#8377;{{purchase_price}}</td>
            <td class="right">&#8377;{{line_total}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <div class="totals-wrap">
      <div class="totals-box">
        <div class="totals-row">
          <span>Subtotal</span>
          <span>&#8377;{{subTotal}}</span>
        </div>
        {{#if hasCouponDiscount}}
        <div class="totals-row discount">
          <span>Coupon Discount</span>
          <span>&minus; &#8377;{{couponDiscount}}</span>
        </div>
        {{/if}}
        <div class="totals-row">
          <span>Shipping Fee</span>
          {{#if freeShipping}}
          <span class="free-ship">FREE</span>
          {{else}}
          <span>&#8377;{{shippingFee}}</span>
          {{/if}}
        </div>
        <div class="totals-row grand">
          <span>Grand Total</span>
          <span>&#8377;{{grandTotal}}</span>
        </div>
      </div>
    </div>

    <div class="footer">
      <p>Thank you for shopping with <span class="brand-accent">FYNDIT</span> &mdash; we appreciate your trust.</p>
      <p>For support, write to us at support@fyndit.com</p>
      <p class="small">This is a computer-generated invoice and does not require a physical signature.</p>
    </div>

  </div>
</body>
</html>
